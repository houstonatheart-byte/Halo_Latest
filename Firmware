String bleRxLine = "";

float extractFloatValue(const String& line, const String& key, bool& found) {
  int idx = line.indexOf(key);

  if (idx < 0) {
    found = false;
    return 0.0f;
  }

  int start = idx + key.length();
  int end = line.indexOf(',', start);

  String valueStr = (end < 0) ? line.substring(start) : line.substring(start, end);
  valueStr.trim();

  found = true;
  return valueStr.toFloat();
}

int extractIntValue(const String& line, const String& key, bool& found) {
  int idx = line.indexOf(key);

  if (idx < 0) {
    found = false;
    return 0;
  }

  int start = idx + key.length();
  int end = line.indexOf(',', start);

  String valueStr = (end < 0) ? line.substring(start) : line.substring(start, end);
  valueStr.trim();

  found = true;
  return valueStr.toInt();
}

