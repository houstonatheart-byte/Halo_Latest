uint32_t waveSeq = 0;
uint32_t tsAckSeq = 0;

uint64_t syncedNowMs() {
  return (uint64_t)((int64_t)millis() + clockOffsetMs);
}

// Manual u64 conversion to avoid formatting problems
String u64ToString(uint64_t value) {
  if (value == 0) return "0";

  String s = "";
  while (value > 0) {
    s = String((uint8_t)(value % 10)) + s;
    value /= 10;
  }

  return s;
}

void applyTimeSyncFromApp(uint64_t appEpochMs) {
  clockOffsetMs = (int64_t)appEpochMs - (int64_t)millis();
  timeSynced = true;
}

void sendTimeSyncAck(uint64_t appEpochMs) {
  if (!Bluefruit.connected()) return;

  String ack = "TS_ACK";
  ack += ",ROLE:" + String((int)DEVICE_ROLE);
  ack += ",SEQ:" + String(tsAckSeq++);
  ack += ",LOCAL_MS:" + String(millis());
  ack += ",SYNC_MS:" + u64ToString(syncedNowMs());
  ack += ",APP_MS:" + u64ToString(appEpochMs);

  bleuart.println(ack);
}

void requestTimeSync() {
  if (!Bluefruit.connected()) return;

  String req = "TS_REQ";
  req += ",ROLE:" + String((int)DEVICE_ROLE);
  req += ",LOCAL_MS:" + String(millis());
  req += ",SYNC_MS:" + u64ToString(syncedNowMs());
  req += ",SYNCED:" + String(timeSynced ? 1 : 0);

  bleuart.println(req);
}

