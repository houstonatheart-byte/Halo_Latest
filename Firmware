void handleCalibrationCommand(const String& line) {
  if (!line.startsWith("CAL,")) return;

  Serial.println("BLE RX CAL: " + line);

  bool changedMax30105Settings = false;
  bool changedSomething = false;

  // --------------------------------------------
  // RESET COMMANDS
  // --------------------------------------------
  if (line.indexOf("RESET_TEMP") >= 0) {
    USER_TEMP_CALIBRATION_OFFSET_C = 0.0f;
    changedSomething = true;
  }

  if (line.indexOf("HR_RESET_DEFAULTS") >= 0) {
    restoreDefaults();
    USER_TEMP_CALIBRATION_OFFSET_C = 0.0f;
    resetHRState();
    resetSpO2State();
    changedMax30105Settings = true;
    changedSomething = true;
  }

  // --------------------------------------------
  // TEMPERATURE USER OFFSET
  // Command example:
  // CAL,TEMP_USER_OFFSET_C:1.25
  // --------------------------------------------
  bool foundFloat = false;
  float newUserTempOffsetC = extractFloatValue(line, "TEMP_USER_OFFSET_C:", foundFloat);

  if (foundFloat) {
    if (newUserTempOffsetC >= -15.0f && newUserTempOffsetC <= 15.0f) {
      USER_TEMP_CALIBRATION_OFFSET_C = newUserTempOffsetC;
      changedSomething = true;
    } else {
      sendCalibrationError("TEMP_USER_OFFSET_OUT_OF_RANGE");
      return;
    }
  }

  // --------------------------------------------
  // HR CONTACT THRESHOLDS
  // Command example:
  // CAL,HR_IR_ON:52000,HR_IR_OFF:46000
  // --------------------------------------------
  bool foundInt = false;

  int newIrOn = extractIntValue(line, "HR_IR_ON:", foundInt);
  if (foundInt) {
    if (newIrOn >= 1000 && newIrOn <= 250000) {
      CONTACT_IR_ON_THRESHOLD = (uint32_t)newIrOn;
      changedSomething = true;
    } else {
      sendCalibrationError("HR_IR_ON_OUT_OF_RANGE");
      return;
    }
  }

  foundInt = false;
  int newIrOff = extractIntValue(line, "HR_IR_OFF:", foundInt);
  if (foundInt) {
    if (newIrOff >= 1000 && newIrOff <= 250000) {
      CONTACT_IR_OFF_THRESHOLD = (uint32_t)newIrOff;
      changedSomething = true;
    } else {
      sendCalibrationError("HR_IR_OFF_OUT_OF_RANGE");
      return;
    }
  }

  // Keep hysteresis valid.
  // ON should normally be greater than OFF.
  if (CONTACT_IR_ON_THRESHOLD <= CONTACT_IR_OFF_THRESHOLD) {
    CONTACT_IR_ON_THRESHOLD = CONTACT_IR_OFF_THRESHOLD + 1000;
  }

  // --------------------------------------------
  // LED AMPLITUDE TUNING
  // Command example:
  // CAL,HR_RED_AMP:80,HR_IR_AMP:80
  //
  // Values should be 0-255 decimal.
  // Example: 0x50 = 80 decimal
  // --------------------------------------------
  foundInt = false;
  int newRedAmp = extractIntValue(line, "HR_RED_AMP:", foundInt);
  if (foundInt) {
    if (newRedAmp >= 0 && newRedAmp <= 255) {
      HR_RED_AMP = (byte)newRedAmp;
      changedMax30105Settings = true;
      changedSomething = true;
    } else {
      sendCalibrationError("HR_RED_AMP_OUT_OF_RANGE");
      return;
    }
  }

  foundInt = false;
  int newIrAmp = extractIntValue(line, "HR_IR_AMP:", foundInt);
  if (foundInt) {
    if (newIrAmp >= 0 && newIrAmp <= 255) {
      HR_IR_AMP = (byte)newIrAmp;
      changedMax30105Settings = true;
      changedSomething = true;
    } else {
      sendCalibrationError("HR_IR_AMP_OUT_OF_RANGE");
      return;
    }
  }

  // --------------------------------------------
  // HR FILTER / SMOOTHING TUNING
  // --------------------------------------------
  foundInt = false;
  int newSmoothStep = extractIntValue(line, "HR_SMOOTH_STEP:", foundInt);
  if (foundInt) {
    if (newSmoothStep >= 1 && newSmoothStep <= 60) {
      HR_SMOOTH_STEP = newSmoothStep;
      changedSomething = true;
    } else {
      sendCalibrationError("HR_SMOOTH_STEP_OUT_OF_RANGE");
      return;
    }
  }

  foundInt = false;
  int newPassthroughBand = extractIntValue(line, "HR_PASSTHROUGH_BAND:", foundInt);
  if (foundInt) {
    if (newPassthroughBand >= 1 && newPassthroughBand <= 80) {
      HR_PASSTHROUGH_BAND = newPassthroughBand;
      changedSomething = true;
    } else {
      sendCalibrationError("HR_PASSTHROUGH_BAND_OUT_OF_RANGE");
      return;
    }
  }

  foundInt = false;
  int newMaxJumpStable = extractIntValue(line, "HR_MAX_JUMP_STABLE:", foundInt);
  if (foundInt) {
    if (newMaxJumpStable >= 1 && newMaxJumpStable <= 100) {
      HR_MAX_JUMP_STABLE = newMaxJumpStable;
      changedSomething = true;
    } else {
      sendCalibrationError("HR_MAX_JUMP_STABLE_OUT_OF_RANGE");
      return;
    }
  }

  foundInt = false;
  int newReacqAgree = extractIntValue(line, "HR_REACQ_AGREE:", foundInt);
  if (foundInt) {
    if (newReacqAgree >= 1 && newReacqAgree <= 100) {
      HR_REACQ_AGREE = newReacqAgree;
      changedSomething = true;
    } else {
      sendCalibrationError("HR_REACQ_AGREE_OUT_OF_RANGE");
      return;
    }
  }

  foundInt = false;
  int newWarmupMs = extractIntValue(line, "WARMUP_MS:", foundInt);
  if (foundInt) {
    if (newWarmupMs >= 0 && newWarmupMs <= 10000) {
      WARMUP_MS = (unsigned long)newWarmupMs;
      changedSomething = true;
    } else {
      sendCalibrationError("WARMUP_MS_OUT_OF_RANGE");
      return;
    }
  }

  // --------------------------------------------
  // APPLY HARDWARE SETTINGS IF NEEDED
  // --------------------------------------------
  if (changedMax30105Settings) {
    applyMax30105Settings();
    resetHRState();
    resetSpO2State();
  }

  if (changedSomething) {
    sendCalibrationAck();
  } else {
    sendCalibrationError("UNKNOWN_CAL_COMMAND");
  }
}

void handleBleIncomingLine(const String& line) {
  Serial.println("BLE RX: " + line);

  // Existing time sync command:
  // TS,APP_MS:...
  if (line.startsWith("TS,")) {
    int idx = line.indexOf("APP_MS:");
    if (idx < 0) return;

    int start = idx + 7;
    int end = line.indexOf(',', start);

    String epochStr = (end < 0) ? line.substring(start) : line.substring(start, end);
    uint64_t appEpochMs = strtoull(epochStr.c_str(), nullptr, 10);

    applyTimeSyncFromApp(appEpochMs);
    sendTimeSyncAck(appEpochMs);
    return;
  }

  // Live calibration/tuning command:
  if (line.startsWith("CAL,")) {
    handleCalibrationCommand(line);
    return;
  }
}

void pollBleRx() {
  while (bleuart.available()) {
    char c = (char)bleuart.read();

    if (c == '\n' || c == '\r') {
      if (bleRxLine.length() > 0) {
        handleBleIncomingLine(bleRxLine);
        bleRxLine = "";
      }
    } else {
      bleRxLine += c;

      // Allow longer tuning commands.
      if (bleRxLine.length() > 280) {
        bleRxLine = "";
      }
    }
  }
}

// ============================================================
// WAVEFORM
// ============================================================
void storeWaveSample(uint32_t redRaw, uint32_t irRaw) {
  if (!ENABLE_WAVEFORM_TX || !fingerOn) return;

  redWaveRing[waveWriteIndex] = (uint16_t)min((uint32_t)65535, (redRaw >> 2));
  irWaveRing[waveWriteIndex]  = (uint16_t)min((uint32_t)65535, (irRaw  >> 2));

  waveWriteIndex = (waveWriteIndex + 1) % WAVE_RING_SAMPLES;
  totalWaveSamplesCaptured++;
}

void sendWaveformWindow() {
  if (!ENABLE_WAVEFORM_TX || !Bluefruit.connected() || !timeSynced) return;

  uint32_t availableSamples = min(totalWaveSamplesCaptured, (uint32_t)WAVE_RING_SAMPLES);
  if (availableSamples < WAVE_UPLOAD_SAMPLES) return;

  uint32_t seq = waveSeq++;

  int32_t startIdx = (int32_t)waveWriteIndex - (int32_t)WAVE_UPLOAD_SAMPLES;
  if (startIdx < 0) startIdx += WAVE_RING_SAMPLES;

  uint64_t endSync = syncedNowMs();
  uint64_t startSync = endSync - ((uint64_t)(WAVE_UPLOAD_SAMPLES - 1) * (1000 / PPG_SAMPLE_RATE_HZ));

  bleuart.println("WF_START,ROLE:" + String((int)DEVICE_ROLE) +
                  ",SEQ:" + String(seq) +
                  ",TS0:" + u64ToString(startSync) +
                  ",DT_MS:" + String(1000 / PPG_SAMPLE_RATE_HZ) +
                  ",N:" + String(WAVE_UPLOAD_SAMPLES));

  for (uint32_t sent = 0; sent < WAVE_UPLOAD_SAMPLES; sent += WF_CHUNK_SAMPLES) {
    String line = "WF_DATA,ROLE:" + String((int)DEVICE_ROLE) +
                  ",SEQ:" + String(seq) +
                  ",OFFSET:" + String(sent) +
                  ",RED:";

    for (uint8_t i = 0; i < WF_CHUNK_SAMPLES && (sent + i) < WAVE_UPLOAD_SAMPLES; i++) {
      line += String(redWaveRing[(startIdx + sent + i) % WAVE_RING_SAMPLES]);
      if (i < WF_CHUNK_SAMPLES - 1 && (sent + i + 1) < WAVE_UPLOAD_SAMPLES) line += "|";
    }

    line += ",IR:";

    for (uint8_t i = 0; i < WF_CHUNK_SAMPLES && (sent + i) < WAVE_UPLOAD_SAMPLES; i++) {
      line += String(irWaveRing[(startIdx + sent + i) % WAVE_RING_SAMPLES]);
      if (i < WF_CHUNK_SAMPLES - 1 && (sent + i + 1) < WAVE_UPLOAD_SAMPLES) line += "|";
    }

    bleuart.println(line);
    delay(8);
  }

  bleuart.println("WF_END,ROLE:" + String((int)DEVICE_ROLE) + ",SEQ:" + String(seq));
}

// ============================================================
// HELPERS & HR PROCESSING
// ============================================================
float getMedianBPM() {
  int n = (bpmBufCount < BPM_BUF_SIZE) ? bpmBufCount : BPM_BUF_SIZE;

  if (n <= 0) return 0.0f;

  float sorted[BPM_BUF_SIZE];

  for (int i = 0; i < n; i++) {
    sorted[i] = bpmBuffer[i];
  }

  for (int i = 0; i < n - 1; i++) {
    for (int j = 0; j < n - i - 1; j++) {
      if (sorted[j] > sorted[j + 1]) {
        float tmp = sorted[j];
        sorted[j] = sorted[j + 1];
        sorted[j + 1] = tmp;
      }
    }
  }

  return sorted[n / 2];
}

void updateSmoothedHR() {
  if (displayHR == 0) {
    smoothedHR = 0;
    return;
  }

  if (smoothedHR == 0) {
    smoothedHR = displayHR;
    return;
  }

  int diff = displayHR - smoothedHR;

  if (abs(diff) <= HR_PASSTHROUGH_BAND) {
    smoothedHR = displayHR;
  } else {
    smoothedHR += (diff > 0) ? HR_SMOOTH_STEP : -HR_SMOOTH_STEP;
  }
}

void seedBuffer(int refHR) {
  for (int i = 0; i < BPM_BUF_SIZE; i++) {
    bpmBuffer[i] = (float)refHR;
  }

  bpmBufIdx = 0;
  bpmBufCount = BPM_BUF_SIZE;
}

void enterReacq() {
  reacqMode = true;
  reacqLastBeat = 0;
  reacqAgreeCount = 0;
  stuckCounter = 0;

  if (displayHR > 0) {
    lastKnownHR = displayHR;
    seedBuffer(displayHR);
  } else if (lastKnownHR > 0) {
    seedBuffer(lastKnownHR);
  }

  displayHR = 0;
}

void resetHRState() {
  bpmBufIdx = 0;
  bpmBufCount = 0;
  lastBeatMs = 0;
  displayHR = 0;
  smoothedHR = 0;
  warmupDone = false;
  reacqMode = true;
  reacqLastBeat = 0;
  reacqAgreeCount = 0;
  stuckCounter = 0;

  for (int i = 0; i < BPM_BUF_SIZE; i++) {
    bpmBuffer[i] = 0;
  }
}

void resetSpO2State() {
  bufferIndex = 0;
  spo2WarmupDone = false;
  spo2ConsecutiveValid = 0;
  displaySpO2 = 0;
  lastCleanSpO2 = 0;
  spo2LowAlert = false;
  spo2LowStartMs = 0;
}

void acceptBeat(int candidate) {
  if (reacqMode) {
    bool hasRef = (lastKnownHR > 0);
    int lockCount = hasRef ? HR_SEED_LOCK_COUNT : HR_COLD_LOCK_COUNT;

    if (hasRef && abs(candidate - lastKnownHR) > HR_SEED_GATE) {
      reacqLastBeat = 0;
      reacqAgreeCount = 0;
      return;
    }

    if (reacqLastBeat == 0) {
      reacqLastBeat = candidate;
      reacqAgreeCount = 1;
      return;
    }

    if (abs(candidate - reacqLastBeat) <= HR_REACQ_AGREE) {
      reacqAgreeCount++;
      reacqLastBeat = candidate;

      if (reacqAgreeCount >= lockCount) {
        displayHR = candidate;
        lastKnownHR = candidate;
        stuckCounter = 0;
        reacqMode = false;
      }
    } else {
      reacqLastBeat = candidate;
      reacqAgreeCount = 1;
    }

    return;
  }

  if (abs(candidate - displayHR) <= HR_MAX_JUMP_STABLE) {
    displayHR = candidate;
    lastKnownHR = candidate;
    stuckCounter = 0;
  } else {
    stuckCounter++;

    if (stuckCounter >= HR_STUCK_LIMIT) {
      lastKnownHR = candidate;
      enterReacq();
    }
  }
}

void handleFingerDetected(long irValue) {
  noFingerCounter = 0;

  if (!fingerOn) {
    fingerOn = true;
    fingerOnTime = millis();

    if (lastKnownHR > 0 && fingerOffTime > 0 && (millis() - fingerOffTime) > HR_STALE_MS) {
      lastKnownHR = 0;
    }

    resetHRState();
    resetSpO2State();

    if (lastKnownHR > 0) {
      seedBuffer(lastKnownHR);
      smoothedHR = lastKnownHR;
    }

    heartSensor.check();

    while (heartSensor.available()) {
      heartSensor.nextSample();
    }

    return;
  }

  if (!warmupDone) {
    checkForBeat(irValue);

    if (millis() - fingerOnTime < WARMUP_MS) return;

    warmupDone = true;
    lastBeatMs = millis();
    return;
  }

  if (checkForBeat(irValue)) {
    long now = millis();
    long delta = now - lastBeatMs;
    lastBeatMs = now;

    if (delta < 333 || delta > 1500) return;

    float bpm = 60000.0f / (float)delta;

    if (bpm < BPM_LOW || bpm > BPM_HIGH) return;

    if (RESPIRATORY_REJECT_MAX_BPM > 0 && bpm < (float)RESPIRATORY_REJECT_MAX_BPM) return;

    bpmBuffer[bpmBufIdx % BPM_BUF_SIZE] = bpm;
    bpmBufIdx++;

    if (bpmBufCount < BPM_BUF_SIZE) {
      bpmBufCount++;
    }

    acceptBeat((int)(getMedianBPM() + 0.5f));
  }
}

void handleFingerRemoved() {
  noFingerCounter++;

  if (noFingerCounter > 100) {
    if (displayHR > 0) {
      lastKnownHR = displayHR;
      fingerOffTime = millis();
    }

    fingerOn = false;
    displayHR = 0;
    displaySpO2 = 0;

    resetHRState();
    resetSpO2State();
  }
}

void shiftSpO2Buffer() {
  for (byte i = SPO2_SHIFT; i < SPO2_BUFFER_LEN; i++) {
    redBuffer[i - SPO2_SHIFT] = redBuffer[i];
    irBuffer[i - SPO2_SHIFT] = irBuffer[i];
  }

  bufferIndex = SPO2_BUFFER_LEN - SPO2_SHIFT;
}

void updateSpO2LowAlert(int cleanSpO2) {
  if (cleanSpO2 <= 0) {
    spo2LowAlert = false;
    spo2LowStartMs = 0;
    return;
  }

  if (cleanSpO2 < SPO2_LOW_ALERT_THRESHOLD) {
    if (spo2LowStartMs == 0) {
      spo2LowStartMs = millis();
      spo2LowAlert = false;
      return;
    }

    spo2LowAlert = ((millis() - spo2LowStartMs) >= SPO2_LOW_HOLD_MS);
  } else {
    spo2LowAlert = false;
    spo2LowStartMs = 0;
  }
}

void processSpO2Buffer() {
  if (!fingerOn) {
    bufferIndex = 0;
    displaySpO2 = 0;
    lastCleanSpO2 = 0;
    spo2ConsecutiveValid = 0;
    updateSpO2LowAlert(0);
    return;
  }

  if (!spo2WarmupDone) {
    spo2WarmupDone = true;
    bufferIndex = 0;
    updateSpO2LowAlert(displaySpO2);
    return;
  }

  maxim_heart_rate_and_oxygen_saturation(
    irBuffer, SPO2_BUFFER_LEN,
    redBuffer, &spo2, &validSPO2,
    &maximHeartRate, &maximValidHR
  );

  static int invalidCount = 0;

  bool cleanSpO2Candidate =
    (validSPO2 == 1 &&
     spo2 >= SPO2_VALID_MIN &&
     spo2 <= SPO2_VALID_MAX);

  if (cleanSpO2Candidate) {
    invalidCount = 0;

    // Reject sudden unrealistic SpO2 jumps once a clean value exists.
    // This reduces noisy optical spikes while still allowing true gradual changes.
    if (lastCleanSpO2 > 0 && abs((int)spo2 - lastCleanSpO2) > 4) {
      spo2ConsecutiveValid = 0;
      updateSpO2LowAlert(displaySpO2);
      shiftSpO2Buffer();
      return;
    }

    spo2ConsecutiveValid++;

    if (spo2ConsecutiveValid >= SPO2_CONFIRM_COUNT) {
      lastCleanSpO2 = (int)spo2;
      displaySpO2 = (int)spo2;
    }
  } else {
    spo2ConsecutiveValid = 0;
    invalidCount++;

    // Do not immediately erase SpO2 on one bad calculation.
    // Only clear it after repeated invalid windows.
    if (invalidCount > 10) {
      displaySpO2 = 0;
      lastCleanSpO2 = 0;
      invalidCount = 0;
    }
  }

  updateSpO2LowAlert(displaySpO2);
  shiftSpO2Buffer();
}

// ============================================================
// IMU / MOTION
// ============================================================
void sampleIMU() {
  float gx = myIMU.readFloatGyroX();
  float gy = myIMU.readFloatGyroY();
  float gz = myIMU.readFloatGyroZ();

  accumulatedGyro += sqrt(gx * gx + gy * gy + gz * gz);

  float ax = myIMU.readFloatAccelX();
  float ay = myIMU.readFloatAccelY();
  float az = myIMU.readFloatAccelZ();

  float am = sqrt(ax * ax + ay * ay + az * az);

  accMagSum += am;
  accMagSqSum += am * am;
  motionSampleCount++;
}

void evaluateMotionStatus() {
  if (motionSampleCount == 0) return;

  float n = (float)motionSampleCount;
  float meanMag = accMagSum / n;
  float accVar = (accMagSqSum / n) - (meanMag * meanMag);
  float avgGyro = accumulatedGyro / n;

  accumulatedGyro = 0;
  accMagSum = 0;
  accMagSqSum = 0;
  motionSampleCount = 0;

  if (avgGyro < GYRO_STILL_THRESHOLD && accVar < ACC_VARIANCE_THRESHOLD) {
    motionStatus = "Still";
  } else if (avgGyro > GYRO_ACTIVE_THRESHOLD) {
    motionStatus = "Active Motion";
  } else {
    motionStatus = "Minor Motion";
  }
}

// ============================================================
// BATTERY
// ============================================================
float readBatteryMv() {
#if HAS_VBAT_ENABLE
  pinMode(VBAT_ENABLE, OUTPUT);
  digitalWrite(VBAT_ENABLE, LOW);
  delay(1);
#endif

  uint32_t raw = analogRead(VBAT_PIN);

#if HAS_VBAT_ENABLE
  digitalWrite(VBAT_ENABLE, HIGH);
#endif

  float voltage = (raw / 4095.0f) * 3.6f * 2.0f;
  return voltage * 1000.0f;
}

// ============================================================
// VITALS PACKET
// ============================================================
void sendVitalsPacket() {
  updateSmoothedHR();

  if (smoothedHR > 0 && smoothedHR == lastReportedHR) {
    stagnantHrCounter++;

    if (stagnantHrCounter >= 40) {
      stagnantHrCounter = 0;
      lastKnownHR = 0;
      enterReacq();
    }
  } else {
    stagnantHrCounter = 0;
  }

  lastReportedHR = smoothedHR;

  evaluateMotionStatus();

  // --- BATTERY SMOOTHING LOGIC ---
  float currentBatt = readBatteryMv();

  if (smoothedBatteryMv == 0) {
    smoothedBatteryMv = currentBatt;
  } else {
    smoothedBatteryMv = (smoothedBatteryMv * 0.9f) + (currentBatt * 0.1f);
  }

  int batteryMv = (int)smoothedBatteryMv;

  String packet = "VT";
  packet += ",ROLE:"     + String((int)DEVICE_ROLE);
  packet += ",BATT:"     + String(batteryMv);
  packet += ",SEQ:"      + String(vitalsSeq++);
  packet += ",LOCAL_MS:" + String(millis());
  packet += ",SYNC_MS:"  + u64ToString(syncedNowMs());
  packet += ",SYNCED:"   + String(timeSynced ? 1 : 0);
  packet += ",CONTACT:"  + String(fingerOn ? 1 : 0);
  packet += ",HR:"       + String(smoothedHR);
  packet += ",SPO2:"     + String(displaySpO2);
  // App should use SPO2_LOW_ALERT as the actual low-SpO2 event flag.
  // This stays 0 until SpO2 has been under 90% for 3+ continuous seconds.
  packet += ",SPO2_LOW_ALERT:" + String(spo2LowAlert ? 1 : 0);
  packet += ",SPO2_LOW_SEC:" + String((spo2LowStartMs > 0 && displaySpO2 > 0 && displaySpO2 < SPO2_LOW_ALERT_THRESHOLD) ? ((millis() - spo2LowStartMs) / 1000) : 0);
  packet += ",SPO2_ALERT_VALUE:" + String(spo2LowAlert ? displaySpO2 : 0);
  packet += ",BMP_OK:" + String(bmpOk ? 1 : 0);
  packet += ",MAX_OK:" + String(maxOk ? 1 : 0);
  packet += ",IMU_OK:" + String(imuOk ? 1 : 0);

  if (bmpOk) {
    float tempC = bmp.readTemperature();

    // Apply both base role offset and live user/app temperature offset.
    tempC += TEMP_CALIBRATION_OFFSET_C;
    tempC += USER_TEMP_CALIBRATION_OFFSET_C;

    float pressure = bmp.readPressure() / 100.0f;
    float altitude = bmp.readAltitude(1013.25f);

    if (isnan(tempC))    tempC    = 0.0f;
    if (isnan(pressure)) pressure = 0.0f;
    if (isnan(altitude)) altitude = 0.0f;

    float tempF = tempC * 1.8f + 32.0f;

    packet += ",TEMP_F:" + String(tempF, 1);
    packet += ",PRESS:"  + String(pressure, 1);
    packet += ",ALT:"    + String(altitude, 1);
  } else {
    packet += ",TEMP_F:0.0,PRESS:0.0,ALT:0.0";
  }

  // Calibration/tuning values included so app can display current firmware state.
  packet += ",TEMP_BASE_OFFSET_C:"  + String(TEMP_CALIBRATION_OFFSET_C, 2);
  packet += ",TEMP_USER_OFFSET_C:"  + String(USER_TEMP_CALIBRATION_OFFSET_C, 2);
  packet += ",TEMP_TOTAL_OFFSET_C:" + String(TEMP_CALIBRATION_OFFSET_C + USER_TEMP_CALIBRATION_OFFSET_C, 2);

  packet += ",HR_IR_ON:" + String(CONTACT_IR_ON_THRESHOLD);
  packet += ",HR_IR_OFF:" + String(CONTACT_IR_OFF_THRESHOLD);
  packet += ",HR_RED_AMP:" + String((int)HR_RED_AMP);
  packet += ",HR_IR_AMP:" + String((int)HR_IR_AMP);
  packet += ",HR_SMOOTH_STEP:" + String(HR_SMOOTH_STEP);
  packet += ",HR_PASSTHROUGH_BAND:" + String(HR_PASSTHROUGH_BAND);
  packet += ",HR_MAX_JUMP_STABLE:" + String(HR_MAX_JUMP_STABLE);
  packet += ",HR_REACQ_AGREE:" + String(HR_REACQ_AGREE);
  packet += ",WARMUP_MS:" + String(WARMUP_MS);

  packet += ",MOTION:" + motionStatus;

  Serial.println(packet);

  if (Bluefruit.connected()) {
    bleuart.println(packet);
  }
}

// ============================================================
// I2C SCAN
// ============================================================
void scanI2C() {
  Serial.println("Scanning I2C bus...");

  int found = 0;

  for (byte addr = 1; addr < 127; addr++) {
    Wire.beginTransmission(addr);
    byte error = Wire.endTransmission();

    if (error == 0) {
      Serial.print("Device found at 0x");

      if (addr < 16) {
        Serial.print("0");
      }

      Serial.println(addr, HEX);
      found++;
    }
  }

  if (found == 0) {
    Serial.println("No I2C devices found");
  } else {
    Serial.println("I2C scan complete");
  }
}

// ============================================================
// SETUP
// ============================================================
void setup() {
  Serial.begin(115200);

  // Give Windows/Arduino Serial Monitor time to reconnect after reset.
  // This prints a visible countdown so the boot section is easier to catch.
  for (int i = 10; i > 0; i--) {
    Serial.print("BOOT WAIT... ");
    Serial.println(i);
    delay(1000);
  }

  Serial.println("BOOT START");
  Serial.println("FIRMWARE VERSION: BMP_DEBUG_FINGER_TEMP_5_6C");

  initSensorConfig();

  Serial.println("CONFIG OK");
  Serial.println("ROLE: " + String((int)DEVICE_ROLE));
  Serial.println("DEVICE NAME: " + String(roleName(DEVICE_ROLE)));
  Serial.println("BASE TEMP OFFSET C: " + String(TEMP_CALIBRATION_OFFSET_C, 2));
  Serial.println("USER TEMP OFFSET C: " + String(USER_TEMP_CALIBRATION_OFFSET_C, 2));
  Serial.println("BPM_LOW: " + String(BPM_LOW, 1));
  Serial.println("BPM_HIGH: " + String(BPM_HIGH, 1));
  Serial.println("HR_LED_BRIGHTNESS: " + String((int)HR_LED_BRIGHTNESS));
  Serial.println("HR_RED_AMP: " + String((int)HR_RED_AMP));
  Serial.println("HR_IR_AMP: " + String((int)HR_IR_AMP));
  Serial.println("SPO2_VALID_MIN: " + String(SPO2_VALID_MIN));
  Serial.println("SPO2_LOW_ALERT_THRESHOLD: " + String(SPO2_LOW_ALERT_THRESHOLD));
  Serial.println("SPO2_LOW_HOLD_MS: " + String(SPO2_LOW_HOLD_MS));

  // Battery divider setup
#if HAS_VBAT_ENABLE
  pinMode(VBAT_ENABLE, OUTPUT);
  digitalWrite(VBAT_ENABLE, HIGH);
#endif

#if HAS_LED_RED
  pinMode(LED_RED, OUTPUT);
  digitalWrite(LED_RED, HIGH);
#endif

#if HAS_LED_GREEN
  pinMode(LED_GREEN, OUTPUT);
  digitalWrite(LED_GREEN, HIGH);
#endif

#if HAS_LED_BLUE
  pinMode(LED_BLUE, OUTPUT);
  digitalWrite(LED_BLUE, HIGH);
#endif

  Wire.begin();
  scanI2C();

  if (!bmp.begin(0x76) && !bmp.begin(0x77)) {
    Serial.println("BMP280 fail — tried 0x76 and 0x77");
    bmpOk = false;
    sensorError = true;
  } else {
    Serial.println("BMP280 OK");
    bmpOk = true;
  }

  if (!heartSensor.begin(Wire, I2C_SPEED_FAST)) {
    Serial.println("MAX30105 fail");
    maxOk = false;
    sensorError = true;
  } else {
    applyMax30105Settings();
    Serial.println("MAX30105 OK");
    maxOk = true;
  }

  if (myIMU.begin() != 0) {
    Serial.println("LSM6DS3 fail");
    imuOk = false;
    sensorError = true;
  } else {
    Serial.println("LSM6DS3 OK");
    imuOk = true;
  }

  Serial.println("BOOT SENSOR STATUS");
  Serial.println("BMP_OK: " + String(bmpOk ? 1 : 0));
  Serial.println("MAX_OK: " + String(maxOk ? 1 : 0));
  Serial.println("IMU_OK: " + String(imuOk ? 1 : 0));

  Bluefruit.configPrphBandwidth(BANDWIDTH_MAX);
  Bluefruit.begin();
  Bluefruit.setName(roleName(DEVICE_ROLE));
  bleuart.begin();

  Bluefruit.Advertising.addFlags(BLE_GAP_ADV_FLAGS_LE_ONLY_GENERAL_DISC_MODE);
  Bluefruit.Advertising.addService(bleuart);

  // Helpful for Android scanning/name visibility.
  Bluefruit.Advertising.addName();
  Bluefruit.ScanResponse.addName();

  Bluefruit.Advertising.restartOnDisconnect(true);
  Bluefruit.Advertising.start(0);

  Serial.println("BLE advertising started");
}

// ============================================================
// LOOP
// ============================================================
void loop() {
  pollBleRx();

  heartSensor.check();

  while (heartSensor.available()) {
    uint32_t r = heartSensor.getFIFORed();
    uint32_t i = heartSensor.getFIFOIR();

    redBuffer[bufferIndex] = r;
    irBuffer[bufferIndex] = i;

    bool contactDetected = fingerOn ? (i > CONTACT_IR_OFF_THRESHOLD)
                                    : (i > CONTACT_IR_ON_THRESHOLD);

    if (contactDetected) {
      handleFingerDetected(i);
      storeWaveSample(r, i);
    } else {
      handleFingerRemoved();
    }

    heartSensor.nextSample();
    bufferIndex++;

    if (bufferIndex >= SPO2_BUFFER_LEN) {
      processSpO2Buffer();

      // Only allow the SpO2 algorithm HR fallback on sites where it has been less problematic.
      // Bicep is intentionally excluded because it was accepting false high values like 166 BPM.
      if (DEVICE_ROLE == ROLE_UPPERCHEST || DEVICE_ROLE == ROLE_WAIST) {
        if (displayHR == 0 && fingerOn && maximValidHR == 1 &&
            maximHeartRate > BPM_LOW && maximHeartRate < BPM_HIGH) {
          acceptBeat(maximHeartRate);
        }
      }
    }
  }

  unsigned long now = millis();

  if (now - lastImuReadTime >= IMU_READ_INTERVAL_MS) {
    lastImuReadTime = now;
    sampleIMU();
  }

  if (Bluefruit.connected() &&
      (now - lastTimeSyncRequestMs >= TIME_SYNC_REQUEST_MS || !timeSynced)) {
    lastTimeSyncRequestMs = now;
    requestTimeSync();
  }

  if (now - lastVitalsTxTime >= VITALS_TX_INTERVAL_MS) {
    lastVitalsTxTime = now;
    sendVitalsPacket();
  }

  if (ENABLE_WAVEFORM_TX && Bluefruit.connected() && timeSynced &&
      (now - lastWaveUploadTime >= WAVE_UPLOAD_PERIOD_MS)) {
    lastWaveUploadTime = now;
    sendWaveformWindow();
  }
}
